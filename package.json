{
  "name": "moontv",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm gen:manifest && node server.js",
    "build": "pnpm gen:manifest && next build",
    "build:cloudflare": "BUILD_TARGET=cloudflare pnpm gen:manifest && npx @opennextjs/cloudflare build",
    "start": "node -e \"process.env.NODE_ENV='production';require('./server.js')\"",
    "preview:cloudflare": "wrangler dev",
    "deploy:cloudflare": "wrangler deploy",
    "lint": "next lint",
    "lint:fix": "eslint src --fix && pnpm format",
    "lint:strict": "eslint --max-warnings=0 src",
    "typecheck": "tsc --noEmit --incremental false",
    "test:watch": "jest --watch",
    "test": "jest",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "gen:manifest": "node scripts/generate-manifest.js",
    "watch-room:server": "node server/watch-room-standalone-server.js --port 3001 --auth YOUR_SECRET_KEY",
    "init:sqlite": "node scripts/init-sqlite.js",
    "init:postgres": "node scripts/init-postgres.js",
    "db:reset": "node -e \"try{['.data/moontv.db','.data/moontv.db-shm','.data/moontv.db-wal'].forEach(f=>{try{require('fs').unlinkSync(f)}catch{}})}\" && node scripts/init-sqlite.js",
    "check:api-unwrap": "node -e \"const{execSync}=require('child_process');try{const r=execSync('rg -l _apiRes_ src/',{encoding:'utf8'});if(r.trim()){console.error('ERROR: Found manual API unwrapping in:');console.error(r);process.exit(1)}else{console.log('OK: No manual API unwrapping found')}}catch(e){if(e.status===1){console.log('OK: No manual API unwrapping found')}else{throw e}}\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^2.2.0",
    "@types/nprogress": "^0.2.3",
    "@upstash/redis": "^1.25.0",
    "@vercel/postgres": "^0.10.0",
    "@vidstack/react": "^1.12.13",
    "anime4k-webgpu": "^1.0.0",
    "artplayer": "^5.3.0",
    "artplayer-plugin-danmuku": "^5.2.0",
    "better-sqlite3": "^12.6.2",
    "bs58": "^6.0.0",
    "cheerio": "^1.1.2",
    "clsx": "^2.0.0",
    "crypto-js": "^4.2.0",
    "dompurify": "^3.4.1",
    "flv.js": "^1.6.2",
    "framer-motion": "^12.18.1",
    "he": "^1.2.0",
    "hls.js": "^1.6.10",
    "https-proxy-agent": "^7.0.6",
    "lucide-react": "^0.438.0",
    "media-icons": "^1.1.5",
    "mux.js": "^6.3.0",
    "nanoid": "^5.1.6",
    "next": "^15.5.15",
    "next-themes": "^0.4.6",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.12",
    "nprogress": "^0.2.0",
    "opencc-js": "^1.0.5",
    "parse-torrent-name": "^0.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.4.0",
    "react-markdown": "^10.1.0",
    "redis": "^4.6.7",
    "remark-gfm": "^3.0.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "swiper": "^11.2.8",
    "tailwind-merge": "^2.6.0",
    "vidstack": "^0.6.15",
    "xml2js": "^0.6.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^2.1.4",
    "@next/eslint-plugin-next": "^16.2.4",
    "@opennextjs/cloudflare": "^1.15.1",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^15.0.7",
    "@types/better-sqlite3": "^7.6.11",
    "@types/bs58": "^5.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/he": "^1.2.3",
    "@types/node": "24.0.3",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.5",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.6",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.15",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.5.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next-router-mock": "^0.9.0",
    "postcss": "^8.5.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vercel": "^50.4.10",
    "webpack-obfuscator": "^3.5.1"
  },
  "packageManager": "pnpm@10.14.0"
}
